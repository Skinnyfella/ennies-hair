# =====================================================================
# Ennie's Hair — environment variables
# Copy this file to `.env` and fill in your own values. Do NOT commit `.env`.
# See SELF_HOSTING.md for where to find each value.
# =====================================================================

# ---- Supabase (browser-visible publishable values) ------------------
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-publishable-key"
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# ---- Supabase (server-side mirrors of the above) --------------------
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-publishable-key"
SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# ---- Supabase (SERVER ONLY — never expose to the browser) -----------
# Bypasses Row Level Security. Used for privileged maintenance only.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ---- Paystack -------------------------------------------------------
# Public key is sent to the browser to open the payment modal.
PAYSTACK_PUBLIC_KEY="pk_test_xxxxxxxxxxxxxxxxxxxx"
# Secret key is server-only and used to verify transactions.
PAYSTACK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"

# ---- EmailJS (order-confirmation emails) ----------------------------
EMAILJS_SERVICE_ID="service_xxxxxxx"
EMAILJS_TEMPLATE_ID="template_xxxxxxx"
EMAILJS_PUBLIC_KEY="your-emailjs-public-key"
